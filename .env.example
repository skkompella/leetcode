# Copy this file to `.env` and fill in your LeetCode cookie values to run the
# sync script locally: `python scripts/sync_submissions.py`.
#
# The GitHub Action does NOT use this file — it reads the repo secrets instead.
# `.env` is gitignored, so your real values never get committed.
#
# Grab both from leetcode.com -> DevTools -> Application -> Cookies -> leetcode.com
LEETCODE_SESSION=
LEETCODE_CSRF_TOKEN=
